<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AsiAirController.ViewModels"
        xmlns:models="using:AsiAirController.Models"
        xmlns:system="using:System"
        xmlns:views="using:AsiAirController.Views"
        xmlns:svc="using:AsiAirController.Services"
        x:Class="AsiAirController.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ASI Air Controller"
        Width="1300" Height="1000"
        CanResize="True"
        MinWidth="900" MinHeight="600"
        Background="#1A1A1A">

    <Window.Styles>
        <Style Selector="TextBlock.sectionHeader">
            <Setter Property="Foreground" Value="#AAAAAA" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="1" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#242424" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#3A7BD5" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A8BE5" />
        </Style>
        <Style Selector="Button.primary:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="TextElement.Foreground" Value="#555555" />
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#C0392B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E74C3C" />
        </Style>
        <Style Selector="Button.danger:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="TextElement.Foreground" Value="#555555" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#444444" />
        </Style>
        <Style Selector="Button.secondary:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="TextElement.Foreground" Value="#555555" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,6" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#E0E0E0" />
        </Style>
    </Window.Styles>

    <Panel>
    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="20">

        <!-- Autopilot banner -->
        <Border Grid.Row="0"
                Background="#1A0F2E"
                BorderBrush="#6A35D4"
                BorderThickness="0,0,0,1"
                Padding="20,8"
                IsVisible="{Binding AutopilotBannerVisible}"
                Margin="-20,-20,-20,0">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Ellipse Width="8" Height="8" Fill="#6A35D4" VerticalAlignment="Center" />
                <TextBlock Text="AUTOPILOT" Foreground="#8B5CF6" FontSize="11"
                           FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center" />
                <TextBlock Text="{Binding AutopilotNightLabel}" Foreground="#C4B5FD"
                           FontSize="11" VerticalAlignment="Center" />
                <TextBlock Text="{Binding AutopilotStatus}" Foreground="#7C6FAD"
                           FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Observatory Time"
                           FontSize="11" Foreground="#555555"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding ObservatoryTimeText}"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#E0E0E0" VerticalAlignment="Center"
                           FontFamily="Courier New, monospace" />
                <TextBlock Text="{Binding ObservatoryTime12Text}"
                           FontSize="13" Foreground="#666666"
                           VerticalAlignment="Center" />
            </StackPanel>
            <Border Grid.Column="1" Background="{Binding RoofBadgeColor}" CornerRadius="6" Padding="14,8"
                    IsVisible="{Binding RoofBadgeVisible}" VerticalAlignment="Center">
                <TextBlock Text="{Binding RoofBadgeText}" Foreground="White"
                           FontSize="13" FontWeight="SemiBold" />
            </Border>
            <Button Grid.Column="2" Classes="secondary"
                    Content="Settings"
                    Command="{Binding OpenSettingsCommand}"
                    FontSize="12" Padding="10,6"
                    HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <!-- Two-column layout: controls+preview on left, plans on right -->
        <Grid Grid.Row="2" ColumnDefinitions="3*,2*">

            <!-- LEFT COLUMN: device, actions, roof status, live preview -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0">

                <!-- CURRENT CONDITIONS (always-on weather poll) -->
                <Border Classes="card">
                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="sectionHeader" Text="CONDITIONS" VerticalAlignment="Center" />
                            <Border Grid.Column="1" Background="#3A1010" CornerRadius="3" Padding="6,2"
                                    IsVisible="{Binding WeatherAlertActive}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Ellipse Width="6" Height="6" Fill="#E05555" VerticalAlignment="Center" />
                                    <TextBlock Text="ALERT" Foreground="#E05555" FontSize="9" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding WeatherCurrentText}"
                                   Foreground="#CCCCCC" FontSize="13"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding WeatherUpdatedText}"
                                   Foreground="#555555" FontSize="10"
                                   IsVisible="{Binding WeatherUpdatedText,
                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <TextBlock Text="{Binding WeatherNextCheckText}"
                                   Foreground="#3A3A3A" FontSize="10"
                                   IsVisible="{Binding WeatherNextCheckText,
                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <!-- StellarVision expanded conditions -->
                        <StackPanel Spacing="4" Margin="0,4,0,0"
                                    IsVisible="{Binding HasStellarVisionData}">
                            <Separator Background="#222222" Height="1" Margin="0,2,0,2" />

                            <!-- Imaging score + safety status -->
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding SvSeeingText}"
                                           Foreground="#AAAAAA" FontSize="11"
                                           TextWrapping="Wrap" VerticalAlignment="Center" />
                                <Border Grid.Column="1" CornerRadius="3" Padding="8,3" Margin="6,0,0,0"
                                        Background="#1A2B1A"
                                        IsVisible="{Binding SvIsSafe}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="#2ECC71" VerticalAlignment="Center" />
                                        <TextBlock Foreground="#2ECC71" FontSize="10" FontWeight="SemiBold">
                                            <Run Text="GO  " /><Run Text="{Binding SvImagingScoreText}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" CornerRadius="3" Padding="8,3" Margin="6,0,0,0"
                                        Background="#2B1A1A"
                                        IsVisible="{Binding !SvIsSafe}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="#E05555" VerticalAlignment="Center" />
                                        <TextBlock Foreground="#E05555" FontSize="10" FontWeight="SemiBold">
                                            <Run Text="NO-GO  " /><Run Text="{Binding SvImagingScoreText}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Safety issues -->
                            <TextBlock Text="{Binding SvSafetyText}"
                                       Foreground="#D4943A" FontSize="11"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding SvSafetyText,
                                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                            <!-- Moon -->
                            <TextBlock Text="{Binding SvMoonText}"
                                       Foreground="#888888" FontSize="11" />

                            <!-- Aurora (only shown when non-trivial) -->
                            <TextBlock Text="{Binding SvAuroraText}"
                                       Foreground="#7A9BD4" FontSize="11"
                                       IsVisible="{Binding SvAuroraText,
                                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                            <!-- NWS summary -->
                            <TextBlock Text="{Binding SvNwsForecast}"
                                       Foreground="#666666" FontSize="10"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding SvNwsForecast,
                                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>

                        <!-- Time-to-night countdown -->
                        <TextBlock Text="{Binding TimeToNightText}"
                                   Foreground="White" FontSize="13"
                                   Margin="0,6,0,0"
                                   IsVisible="{Binding TimeToNightText,
                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <!-- Sun timeline bar -->
                        <views:SunTimelineControl x:Name="SunTimeline"
                                                  Margin="0,6,0,0"
                                                  IsVisible="{Binding SunTimes,
                                                              Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                </Border>

                <!-- TRACKING: autofocus + guiding status -->
                <Border Classes="card" IsVisible="{Binding HasTrackingData}">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionHeader" Text="TRACKING" />

                        <!-- AutoFocus row -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding AutoFocusStatus,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <Ellipse Width="7" Height="7" Fill="#3A7BD5" VerticalAlignment="Center"
                                     IsVisible="{Binding IsAutoFocusActive}" />
                            <Ellipse Width="7" Height="7" Fill="#555555" VerticalAlignment="Center"
                                     IsVisible="{Binding !IsAutoFocusActive}" />
                            <TextBlock Text="Autofocus" Foreground="#888888" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding AutoFocusStatus}" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Guide row -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding GuideStatus,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <Ellipse Width="7" Height="7" Fill="#2ECC71" VerticalAlignment="Center"
                                     IsVisible="{Binding IsGuiding}" />
                            <Ellipse Width="7" Height="7" Fill="#555555" VerticalAlignment="Center"
                                     IsVisible="{Binding !IsGuiding}" />
                            <TextBlock Text="RMS" Foreground="#888888" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding GuideStatus}" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Guide graph -->
                        <views:GuideGraphControl x:Name="GuideGraph"
                                                 Height="80"
                                                 IsVisible="{Binding GuidePoints.Count,
                                                             Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                </Border>




                <!-- OBSERVATORY CAMERAS -->
                <Border Classes="card" Margin="0,0,0,12"
                        IsVisible="{Binding BuildingCamBitmap,
                                    Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionHeader" Text="CAMERAS" />
                        <Grid ColumnDefinitions="*,*" >
                            <!-- Building cam -->
                            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,4,0">
                                <Border Background="#0D0D0D" CornerRadius="3" Height="220">
                                    <Image Source="{Binding BuildingCamBitmap}" Stretch="UniformToFill" />
                                </Border>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Building" Foreground="#555555" FontSize="10" />
                                    <TextBlock Text="{Binding BuildingCamTimestamp}"
                                               Foreground="#3A3A3A" FontSize="10" />
                                </StackPanel>
                            </StackPanel>
                            <!-- All-sky cam -->
                            <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0">
                                <Border Background="#0D0D0D" CornerRadius="3" Height="220">
                                    <Image Source="{Binding AllSkyCamBitmap}" Stretch="UniformToFill" />
                                </Border>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="All-sky" Foreground="#555555" FontSize="10" />
                                    <TextBlock Text="{Binding AllSkyCamTimestamp}"
                                               Foreground="#3A3A3A" FontSize="10" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- DEVICE STATS: temps, storage, session status -->
                <Border Classes="card"
                        IsVisible="{Binding IsPreviewActive}"
                        Margin="0,0,0,12">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="sectionHeader" Text="DEVICE" />

                        <!-- Stats row: camera temp · pi temp · storage -->
                        <WrapPanel Orientation="Horizontal">
                            <Border Background="#0D1E2E" CornerRadius="3" Padding="8,4"
                                    Margin="0,0,6,6"
                                    IsVisible="{Binding CameraTemperatureText,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="6" Height="6" Fill="#5BA3D4" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding CameraTemperatureText}"
                                               Foreground="#9BC4D4" FontSize="11"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#0D1E2E" CornerRadius="3" Padding="8,4"
                                    Margin="0,0,6,6"
                                    IsVisible="{Binding PiTemperatureText,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="6" Height="6" Fill="#D47A5B" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding PiTemperatureText}"
                                               Foreground="#D4A59B" FontSize="11"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#0D1E2E" CornerRadius="3" Padding="8,4"
                                    Margin="0,0,0,6"
                                    IsVisible="{Binding StorageText,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="6" Height="6" Fill="#5BD47A" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StorageText}"
                                               Foreground="#9BD4A9" FontSize="11"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!-- Session activity status pill -->
                        <Border Background="#111827" CornerRadius="4" Padding="10,7"
                                IsVisible="{Binding HasPlanStatus}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse Width="9" Height="9"
                                         Fill="{Binding PlanStatusColor}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="STATUS" Foreground="#555555"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           LetterSpacing="1" />
                                <TextBlock Text="{Binding PlanStatusText}"
                                           Foreground="#E0E0E0" FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- LIVE PREVIEW: image only -->
                <Border Classes="card" Margin="0,0,0,12">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="sectionHeader" Text="LIVE PREVIEW" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PreviewStatus}"
                                       Foreground="#888888" FontSize="11"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <ProgressBar Value="{Binding DownloadProgressValue}"
                                     Minimum="0" Maximum="1"
                                     IsVisible="{Binding IsDownloading}"
                                     Height="6" CornerRadius="3"
                                     Margin="0,0,0,4" />
                        <Border Background="#0D0D0D" CornerRadius="4" Height="{Binding PreviewImageMaxHeight}">
                            <Panel>
                                <TextBlock Text="Waiting for first image..."
                                           Foreground="#555555" FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,40"
                                           IsVisible="{Binding PreviewBitmap,
                                                       Converter={x:Static ObjectConverters.IsNull}}" />
                                <Image Source="{Binding PreviewBitmap}"
                                       Stretch="Uniform"
                                       IsVisible="{Binding PreviewBitmap,
                                                   Converter={x:Static ObjectConverters.IsNotNull}}" />
                            </Panel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
            </ScrollViewer>

            <!-- RIGHT COLUMN: Actions, Dew Heater, Plans + Autopilot tabs -->
            <Grid Grid.Column="1" Margin="12,0,0,0" RowDefinitions="Auto,Auto,*">

                <!-- ACTIONS -->
                <Border Grid.Row="0" Classes="card">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="sectionHeader" Text="ACTIONS" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{Binding ExposureSeconds}"
                                     Width="60"
                                     Background="#1A1A1A"
                                     Foreground="#E0E0E0"
                                     BorderBrush="#444444"
                                     CaretBrush="#E0E0E0"
                                     Padding="8,7"
                                     CornerRadius="6"
                                     FontSize="13" />
                            <TextBlock Text="sec" Foreground="#888888" FontSize="12"
                                       VerticalAlignment="Center" />
                            <Button Classes="primary" Content="Take Image"
                                    Command="{Binding TakeImageCommand}" />
                        </StackPanel>
                        <WrapPanel>
                            <Button Classes="secondary" Content="Stop Exposure"
                                    Command="{Binding StopExposureCommand}"
                                    Margin="0,0,10,8" />
                            <Button Classes="primary" Content="Park Mount"
                                    Command="{Binding ParkMountCommand}"
                                    Margin="0,0,10,8" />
                            <Button Classes="danger" Content="Safe Shutdown"
                                    Command="{Binding SafeShutdownCommand}"
                                    Margin="0,0,10,8" />
                            <Button Classes="secondary" Content="Check Roof"
                                    Command="{Binding CheckRoofStatusCommand}"
                                    Margin="0,0,10,8" />
                            <Button Classes="secondary"
                                    Content="{Binding SyncButtonText}"
                                    Command="{Binding SyncImagesManuallyCommand}"
                                    IsVisible="{Binding HasSyncPaths}"
                                    Margin="0,0,10,8" />
                        </WrapPanel>

                        <!-- Copy progress bar — visible only while manual sync runs -->
                        <ProgressBar Value="{Binding ManualSyncProgress}"
                                     Minimum="0" Maximum="1"
                                     Height="4" CornerRadius="2"
                                     Foreground="#5BA3D4"
                                     Background="#1A2E3A"
                                     IsVisible="{Binding IsSyncingManually}" />
                    </StackPanel>
                </Border>

                <!-- DEW HEATER -->
                <Border Grid.Row="1" Classes="card">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="sectionHeader" Text="DEW HEATER" VerticalAlignment="Center" />
                            <Border Grid.Column="1" Background="#1A2E1A" CornerRadius="3" Padding="5,2"
                                    IsVisible="{Binding IsWeatherMonitoring}">
                                <TextBlock Text="MONITORING" Foreground="#2ECC71" FontSize="9" FontWeight="Bold" />
                            </Border>
                        </Grid>

                        <!-- Source selection -->
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <RadioButton Content="Kasa (cloud)"
                                         IsChecked="{Binding DewHeaterIsKasa}"
                                         Foreground="#CCCCCC" FontSize="12"
                                         Command="{Binding SetDewHeaterSourceKasaCommand}" />
                            <RadioButton Content="ASI Air Output"
                                         IsChecked="{Binding DewHeaterIsAsiAirPort}"
                                         Foreground="#CCCCCC" FontSize="12"
                                         Command="{Binding SetDewHeaterSourceAsiAirCommand}" />
                        </StackPanel>

                        <!-- ASI Air output index (only when source = AsiAirOutput) -->
                        <Grid ColumnDefinitions="Auto,8,*"
                              IsVisible="{Binding DewHeaterIsAsiAirPort}">
                            <TextBlock Grid.Column="0" Text="Output:"
                                       Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding PowerOutputs}"
                                      SelectedIndex="{Binding DewHeaterAsiAirOutputIndex}"
                                      Background="#1A1A1A" Foreground="#E0E0E0"
                                      BorderBrush="#444444" Padding="8,6"
                                      CornerRadius="6" FontSize="12"
                                      HorizontalAlignment="Stretch"
                                      PlaceholderText="Connect ASI Air to see outputs">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PowerOutputViewModel">
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <!-- Kasa device picker (only when source = Kasa) -->
                        <ComboBox ItemsSource="{Binding KasaDevices}"
                                  SelectedItem="{Binding SelectedKasaDevice}"
                                  IsVisible="{Binding DewHeaterIsKasa}"
                                  PlaceholderText="Select Kasa device…"
                                  Background="#1A1A1A" Foreground="#E0E0E0"
                                  BorderBrush="#444444" Padding="8,6"
                                  CornerRadius="6" FontSize="12"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:KasaDevice">
                                    <TextBlock Text="{Binding Alias}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="Configure Kasa credentials in Settings → Kasa Account"
                                   Foreground="#666666" FontSize="11"
                                   IsVisible="{Binding DewHeaterIsKasa}" />

                        <!-- Toggle + state badge -->
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Button Classes="primary"
                                    Content="{Binding DewHeaterButtonText}"
                                    Command="{Binding ToggleDewHeaterCommand}"
                                    IsEnabled="{Binding !IsKasaBusy}"
                                    FontSize="12" Padding="12,6" />
                            <Panel IsVisible="{Binding IsDewHeaterStateKnown}">
                                <Border CornerRadius="4" Padding="8,4" Background="#18261E"
                                        IsVisible="{Binding IsDewHeaterOn}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Ellipse Width="7" Height="7" Fill="#2ECC71" VerticalAlignment="Center" />
                                        <TextBlock Text="ON" Foreground="#2ECC71" FontSize="11" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="4" Padding="8,4" Background="#2A1510"
                                        IsVisible="{Binding !IsDewHeaterOn}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Ellipse Width="7" Height="7" Fill="#E74C3C" VerticalAlignment="Center" />
                                        <TextBlock Text="OFF" Foreground="#E74C3C" FontSize="11" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </Panel>
                        </StackPanel>

                        <TextBlock Text="{Binding KasaStatusMessage}"
                                   Foreground="#888888" FontSize="11" TextWrapping="Wrap"
                                   IsVisible="{Binding KasaStatusMessage,
                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <Border Background="#111A26" CornerRadius="4" Padding="8,6"
                                IsVisible="{Binding IsWeatherMonitoring}">
                            <TextBlock Text="{Binding WeatherMonitorStatus}"
                                       Foreground="#7AABDB" FontSize="11"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ASI AIR POWER OUTPUTS -->
                <Border Grid.Row="1" Classes="card">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionHeader" Text="ASI AIR POWER OUTPUTS" />
                        <TextBlock Text="Connect to ASI Air to see outputs"
                                   Foreground="#555555" FontSize="11"
                                   IsVisible="{Binding !HasPowerOutputs}" />

                        <ItemsControl x:Name="PowerOutputList"
                                      ItemsSource="{Binding PowerOutputs}"
                                      IsVisible="{Binding HasPowerOutputs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PowerOutputViewModel">
                                    <Border Padding="0,6,0,6"
                                            BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,10,Auto,10,Auto">

                                            <!-- Label + live readings -->
                                            <StackPanel Grid.Column="0" Spacing="3">
                                                <TextBox Text="{Binding Label}"
                                                         Watermark="{Binding DefaultName}"
                                                         Background="Transparent"
                                                         BorderThickness="0,0,0,1"
                                                         BorderBrush="#333333"
                                                         Foreground="#E0E0E0"
                                                         FontSize="12" Padding="0,2" />
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock Text="{Binding VoltageText}"
                                                               Foreground="#666666" FontSize="10" />
                                                    <TextBlock Text="{Binding CurrentText}"
                                                               Foreground="#666666" FontSize="10" />
                                                    <Border CornerRadius="3" Padding="5,2"
                                                            Background="#18261E"
                                                            IsVisible="{Binding IsOn}">
                                                        <TextBlock Text="ON" Foreground="#2ECC71"
                                                                   FontSize="9" FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border CornerRadius="3" Padding="5,2"
                                                            Background="#2A1510"
                                                            IsVisible="{Binding !IsOn}">
                                                        <TextBlock Text="OFF" Foreground="#E74C3C"
                                                                   FontSize="9" FontWeight="SemiBold" />
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Toggle button -->
                                            <Button Grid.Column="2"
                                                    Classes="secondary"
                                                    Content="{Binding ToggleButtonText}"
                                                    Command="{ReflectionBinding DataContext.TogglePowerOutputCommand, ElementName=PowerOutputList}"
                                                    CommandParameter="{Binding}"
                                                    FontSize="11" Padding="8,4"
                                                    VerticalAlignment="Top" />

                                            <!-- Plan-start / plan-end checkboxes -->
                                            <StackPanel Grid.Column="4" Spacing="4" VerticalAlignment="Top">
                                                <CheckBox IsChecked="{Binding PowerOnAtPlanStart}"
                                                          Foreground="#AAAAAA" FontSize="10"
                                                          Content="On at plan start" />
                                                <CheckBox IsChecked="{Binding PowerOffAtPlanEnd}"
                                                          Foreground="#AAAAAA" FontSize="10"
                                                          Content="Off at plan end" />
                                            </StackPanel>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <TabControl Grid.Row="2"
                            Background="Transparent"
                            BorderThickness="0">

            <!-- PLANS TAB -->
            <TabItem Header="Plans">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="sectionHeader" Text="PLANS" />
                        <Button Classes="secondary" Content="Refresh"
                                Command="{Binding LoadPlansCommand}"
                                FontSize="12" Padding="10,5" />
                    </Grid>

                    <TextBlock Text="Loading plans…"
                               Foreground="#888888" FontSize="12"
                               IsVisible="{Binding IsLoadingPlans}" />

                    <TextBlock Text="No plans loaded — press Refresh"
                               Foreground="#555555" FontSize="12"
                               IsVisible="{Binding ShowPlansEmptyState}" />

                    <!-- Active plan detail -->
                    <Border IsVisible="{Binding HasActivePlan}"
                            Classes.running="{Binding IsPlanRunning}"
                            Background="#18261E"
                            BorderBrush="#2ECC71" BorderThickness="3,0,0,0"
                            CornerRadius="4" Padding="12">
                        <Border.Styles>
                            <Style Selector="Border.running">
                                <Setter Property="Background" Value="#26200E" />
                                <Setter Property="BorderBrush" Value="#E67E22" />
                            </Style>
                        </Border.Styles>
                        <StackPanel Spacing="5">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding ActivePlanDetail.Name}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="#E0E0E0"
                                           VerticalAlignment="Center" />
                                <!-- RUNNING badge (plan executing) -->
                                <Border Grid.Column="1"
                                        Background="#E67E22" CornerRadius="3"
                                        Padding="6,2" VerticalAlignment="Center"
                                        IsVisible="{Binding IsPlanRunning}">
                                    <TextBlock Text="RUNNING"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#1A0D00" />
                                </Border>
                                <!-- ACTIVE badge (plan set, not running) -->
                                <Border Grid.Column="1"
                                        Background="#2ECC71" CornerRadius="3"
                                        Padding="6,2" VerticalAlignment="Center"
                                        IsVisible="{Binding !IsPlanRunning}">
                                    <TextBlock Text="ACTIVE"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#0F1F0F" />
                                </Border>
                            </Grid>
                            <ProgressBar Value="{Binding LiveProgressFraction}"
                                         Minimum="0" Maximum="1"
                                         Height="4" CornerRadius="2"
                                         Margin="0,2,0,0" />
                            <TextBlock Text="{Binding LiveFrameText}"
                                       Foreground="#888888" FontSize="11"
                                       IsVisible="{Binding LiveFrameText,
                                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            <Border Background="#1A1A2E" CornerRadius="3" Padding="8,4"
                                    IsVisible="{Binding IsWaitingForDusk}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="⏳" FontSize="11" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding DuskCountdownText}"
                                               Foreground="#9B7FD4" FontSize="11"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#0D2E0D" CornerRadius="3" Padding="8,4"
                                    IsVisible="{Binding ExposureCountdownText,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="6" Height="6" Fill="#4CAF50"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ExposureCountdownText}"
                                               Foreground="#9BD49B" FontSize="11"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="{Binding ActivePlanTimeText}"
                                       Foreground="#CCCCCC" FontSize="12" />
                            <TextBlock Text="{Binding ActivePlanDataText}"
                                       Foreground="#CCCCCC" FontSize="12" />
                            <TextBlock Text="{Binding ActivePlanScheduleText}"
                                       Foreground="#888888" FontSize="11" />
                            <TextBlock Text="{Binding ActivePlanTargetsText}"
                                       Foreground="#CCCCCC" FontSize="12"
                                       IsVisible="{Binding ActivePlanTargetsText,
                                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            <ItemsControl ItemsSource="{Binding ActivePlanSlots}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="system:String">
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#777777" FontSize="11"
                                                   FontFamily="Courier New, monospace"
                                                   Margin="0,1" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Start / Auto Run controls -->
                            <StackPanel Spacing="6" Margin="0,8,0,0">

                                <!-- Button row — hidden while confirming manual start -->
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            IsVisible="{Binding !IsConfirmingStartPlan}">
                                    <Button Classes="secondary"
                                            Content="Start Now"
                                            Command="{Binding ShowStartPlanConfirmCommand}"
                                            FontSize="12" Padding="12,6" />
                                    <Button Classes="secondary"
                                            Content="Reset"
                                            Command="{Binding ResetActivePlanCommand}"
                                            FontSize="12" Padding="12,6" />
                                    <Button Classes="primary"
                                            Content="{Binding AutoRunButtonText}"
                                            Command="{Binding StartAutoRunCommand}"
                                            IsVisible="{Binding !IsAutoRunActive}"
                                            FontSize="12" Padding="12,6" />
                                    <Button Classes="danger"
                                            Content="■  Stop Auto Run"
                                            Command="{Binding StopAutoRunCommand}"
                                            IsVisible="{Binding IsAutoRunActive}"
                                            FontSize="12" Padding="12,6" />
                                </StackPanel>

                                <!-- Auto Run setup hint -->
                                <TextBlock Text="Auto Run requires a Roof Status File or Starfront Building ID — configure in Settings."
                                           FontSize="11" Foreground="#888888"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding ShowAutoRunSetupHint}" />

                                <!-- Manual start confirmation -->
                                <StackPanel IsVisible="{Binding IsConfirmingStartPlan}" Spacing="6">
                                    <TextBlock Text="{Binding StartPlanConfirmText}"
                                               Foreground="#E0E0E0" FontSize="12"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Classes="primary"
                                                Content="Yes, Start"
                                                Command="{Binding ConfirmStartPlanCommand}"
                                                FontSize="12" Padding="12,6" />
                                        <Button Classes="secondary"
                                                Content="Cancel"
                                                Command="{Binding CancelStartPlanConfirmCommand}"
                                                FontSize="12" Padding="12,6" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Auto Run status pill -->
                                <Border Background="#0D1520" CornerRadius="4" Padding="10,8"
                                        IsVisible="{Binding IsAutoRunActive}">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Panel Grid.Column="0" Width="8" Height="8"
                                               VerticalAlignment="Top" Margin="0,3,8,0">
                                            <Ellipse Fill="#F0C040"
                                                     IsVisible="{Binding IsAutoRunWaiting}" />
                                            <Ellipse Fill="#2ECC71"
                                                     IsVisible="{Binding IsAutoRunRunning}" />
                                        </Panel>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding AutoRunStatus}"
                                                       Foreground="#AAAAAA" FontSize="11"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding AutoRunNextCheckText}"
                                                       Foreground="#3A3A3A" FontSize="10"
                                                       IsVisible="{Binding AutoRunNextCheckText,
                                                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Inactive plans -->
                    <ItemsControl x:Name="InactivePlansList"
                                  ItemsSource="{Binding InactivePlans}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:PlanSummary">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      Margin="0,0,0,6">
                                    <Ellipse Width="8" Height="8" Fill="#555555"
                                             VerticalAlignment="Center"
                                             Margin="0,0,10,0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" Foreground="#CCCCCC" />
                                        <TextBlock Text="{Binding TargetCount, StringFormat='{}{0} target(s)'}"
                                                   FontSize="11" Foreground="#666666" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Classes="secondary"
                                            Content="Set Active"
                                            Command="{ReflectionBinding DataContext.SetActivePlanCommand, ElementName=InactivePlansList}"
                                            CommandParameter="{Binding}"
                                            FontSize="12" Padding="10,6" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Imaging-active warning -->
                    <Border Background="#2A1F10" CornerRadius="4" Padding="10,6"
                            IsVisible="{Binding IsImagingActive}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="⚠" Foreground="#E67E22" FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Stop imaging before swapping plans"
                                       Foreground="#E67E22" FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
            </ScrollViewer>
            </TabItem>

            <!-- AUTOPILOT TAB -->
            <TabItem Header="Autopilot">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Margin="0,8,0,0">

                <!-- Active status banner -->
                <Border Background="#1A0F2E" CornerRadius="6" Padding="12,10"
                        IsVisible="{Binding IsAutopilotActive}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding AutopilotNightLabel}"
                                   Foreground="#C4B5FD" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding AutopilotStatus}"
                                   Foreground="#9B7FD4" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Tonight's top targets -->
                <Border Classes="card">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="sectionHeader" Text="TONIGHT'S TARGETS" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Classes="secondary"
                                    Content="Refresh"
                                    Command="{Binding RefreshTonightCandidatesCommand}"
                                    IsEnabled="{Binding !IsLoadingCandidates}"
                                    FontSize="11" Padding="8,4" />
                        </Grid>
                        <TextBlock Text="{Binding CandidatesStatusText}"
                                   Foreground="#555555" FontSize="10"
                                   IsVisible="{Binding CandidatesStatusText,
                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <ItemsControl ItemsSource="{Binding TonightCandidates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TonightCandidate">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4,0,0">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Rank, StringFormat='{}{0}.'}"
                                                   Foreground="#444444" FontSize="11"
                                                   VerticalAlignment="Top"
                                                   Margin="0,1,8,0" Width="16" />
                                        <StackPanel Grid.Column="1" Spacing="1">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#E0E0E0" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding TypeWindow}"
                                                       Foreground="#666666" FontSize="10" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Imaged}"
                                                   Foreground="#3A7BD5" FontSize="10"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding Imaged,
                                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Classes="secondary"
                                Content="View All →"
                                Command="{Binding OpenCandidatesOverlayCommand}"
                                IsVisible="{Binding HasTonightCandidates}"
                                HorizontalAlignment="Right"
                                FontSize="11" Padding="8,4" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Night queue -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="NIGHT QUEUE" />
                        <TextBlock Text="Add plans in the order you want them to run. The list cycles each night."
                                   Foreground="#777777" FontSize="11" TextWrapping="Wrap" />

                        <ItemsControl x:Name="AutopilotQueueList"
                                      ItemsSource="{Binding AutopilotNights}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:AutopilotNightEntry">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,0,0,6">
                                        <TextBlock Grid.Column="0" Text="☽"
                                                   Foreground="#6A35D4" FontSize="13"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding PlanName}"
                                                   Foreground="#CCCCCC" FontSize="12"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="2" Classes="secondary" Content="↑"
                                                Command="{ReflectionBinding DataContext.MoveAutopilotNightUpCommand, ElementName=AutopilotQueueList}"
                                                CommandParameter="{Binding}"
                                                FontSize="11" Padding="8,5" Margin="4,0,0,0" />
                                        <Button Grid.Column="3" Classes="secondary" Content="↓"
                                                Command="{ReflectionBinding DataContext.MoveAutopilotNightDownCommand, ElementName=AutopilotQueueList}"
                                                CommandParameter="{Binding}"
                                                FontSize="11" Padding="8,5" Margin="4,0,0,0" />
                                        <Button Grid.Column="4" Classes="danger" Content="✕"
                                                Command="{ReflectionBinding DataContext.RemoveAutopilotNightCommand, ElementName=AutopilotQueueList}"
                                                CommandParameter="{Binding}"
                                                FontSize="11" Padding="8,5" Margin="4,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Add plan:" Foreground="#888888" FontSize="11" Margin="0,4,0,0" />
                        <ItemsControl x:Name="AvailablePlansForAutopilot"
                                      ItemsSource="{Binding Plans}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:PlanSummary">
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Foreground="#CCCCCC" FontSize="12"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Classes="secondary" Content="+ Add Night"
                                                Command="{ReflectionBinding DataContext.AddAutopilotNightCommand, ElementName=AvailablePlansForAutopilot}"
                                                CommandParameter="{Binding}"
                                                FontSize="11" Padding="8,5" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Autopilot settings -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="AUTOPILOT SETTINGS" />

                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Number of nights" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" />
                            <TextBox Text="{Binding AutopilotNightCountText}"
                                     Width="56"
                                     Background="#1A1A1A" Foreground="#E0E0E0"
                                     BorderBrush="#444444" CaretBrush="#E0E0E0"
                                     Padding="8,7" CornerRadius="6" FontSize="12" />
                            <TextBlock Text="(0 = run forever)" Foreground="#888888" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Power on" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" />
                            <TextBox Text="{Binding AutopilotPowerOnOffsetText}"
                                     Width="56"
                                     Background="#1A1A1A" Foreground="#E0E0E0"
                                     BorderBrush="#444444" CaretBrush="#E0E0E0"
                                     Padding="8,7" CornerRadius="6" FontSize="12" />
                            <TextBlock Text="minutes before dusk" Foreground="#888888" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Auto-target planner toggle -->
                <Border Classes="card">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionHeader" Text="AUTO-TARGET PLANNER" />
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <CheckBox IsChecked="{Binding AutoPlannerEnabled}"
                                      Content="Auto-select best DSO target each night"
                                      Foreground="#CCCCCC" FontSize="12" />
                        </StackPanel>
                        <TextBlock Text="{Binding AutoPlannerStatus}"
                                   Foreground="#A78BFA" FontSize="11"
                                   IsVisible="{Binding AutoPlannerEnabled}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="When enabled, the autopilot will score tonight's catalog each night, pick the best visible object, and create a new ASI Air plan automatically. Configure equipment and preferences in Settings."
                                   Foreground="#555555" FontSize="10" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Start / Stop buttons -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Classes="primary"
                            Content="▶  Start Autopilot"
                            Command="{Binding StartAutopilotCommand}"
                            IsVisible="{Binding !IsAutopilotActive}"
                            FontSize="13" Padding="14,9" />
                    <Button Classes="danger"
                            Content="■  Stop Autopilot"
                            Command="{Binding StopAutopilotCommand}"
                            IsVisible="{Binding IsAutopilotActive}"
                            FontSize="13" Padding="14,9" />
                </StackPanel>

            </StackPanel>
            </ScrollViewer>
            </TabItem>

            <!-- LIBRARY TAB -->
            <TabItem Header="Library">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Margin="0,8,0,0">

                <!-- Scan card -->
                <Border Classes="card">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Classes="sectionHeader" Text="LIGHT LIBRARY" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Classes="secondary"
                                    Content="Scan"
                                    Command="{Binding ScanLightLibraryCommand}"
                                    IsEnabled="{Binding !IsLibraryScanning}"
                                    FontSize="12" Padding="10,6" />
                        </Grid>
                        <TextBlock Text="Reads the Image Sync destination folder to show accumulated light frames per target."
                                   Foreground="#555555" FontSize="10" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding LibraryStatusText}"
                                   Foreground="#AAAAAA" FontSize="11"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding LibraryStatusText,
                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </Border>

                <!-- Target list -->
                <ItemsControl x:Name="LightTargetsList"
                              ItemsSource="{Binding LightTargets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="svc:LightTarget">
                            <Border Classes="card">
                                <StackPanel Spacing="6">

                                    <!-- Name + plan button (single targets only) -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="#E0E0E0" FontSize="13" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <Button Grid.Column="1" Classes="secondary"
                                                Content="Generate Plan"
                                                Command="{ReflectionBinding DataContext.GenerateLibraryPlanCommand, ElementName=LightTargetsList}"
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding !IsMosaic}"
                                                FontSize="11" Padding="8,5" />
                                    </Grid>

                                    <!-- Summary line -->
                                    <TextBlock Text="{Binding Summary}"
                                               Foreground="#888888" FontSize="11" />

                                    <!-- Mosaic panel breakdown -->
                                    <ItemsControl ItemsSource="{Binding Panels}"
                                                  IsVisible="{Binding IsMosaic}"
                                                  Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="svc:MosaicPanel">
                                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,3,0,0">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Name}"
                                                               Foreground="#666666" FontSize="11"
                                                               VerticalAlignment="Center"
                                                               MinWidth="110" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Summary}"
                                                               Foreground="#777777" FontSize="11"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="2" Classes="secondary"
                                                            Content="Plan"
                                                            Command="{ReflectionBinding DataContext.GenerateLibraryPlanCommand, ElementName=LightTargetsList}"
                                                            CommandParameter="{Binding}"
                                                            FontSize="10" Padding="6,4" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
            </ScrollViewer>
            </TabItem>

            </TabControl>

            </Grid><!-- end right column Grid -->

        </Grid>

        <!-- SESSION LOG -->
        <Border Grid.Row="3" Margin="0,12,0,0"
                Background="#1C1C1C"
                BorderBrush="#2A2A2A"
                BorderThickness="0,1,0,0"
                Padding="0,10,0,4">
            <Grid RowDefinitions="Auto,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="0,0,0,6">
                    <Button Grid.Column="0" Classes="secondary"
                            Content="{Binding LogChevron}"
                            Command="{Binding ToggleLogCommand}"
                            FontSize="11" Padding="6,4" Margin="0,0,8,0" />
                    <TextBlock Grid.Column="1" Classes="sectionHeader" Text="SESSION LOG"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="3" Classes="secondary" Content="Clear"
                            Command="{Binding ClearLogCommand}"
                            FontSize="11" Padding="8,4" Margin="0,0,8,0" />
                    <Button Grid.Column="4" Classes="secondary" Content="Delete Files"
                            Command="{Binding DeleteLogFilesCommand}"
                            FontSize="11" Padding="8,4" Margin="0,0,8,0" />
                    <Button Grid.Column="5" Classes="secondary" Content="Open Folder"
                            Command="{Binding OpenLogFolderCommand}"
                            FontSize="11" Padding="8,4" />
                </Grid>
                <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer"
                              Height="160"
                              IsVisible="{Binding IsLogExpanded}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:LogEntry">
                                <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,1,0,0">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                               Foreground="#3A3A4A"
                                               FontSize="11"
                                               FontFamily="Courier New, monospace"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Top" />
                                    <Border Grid.Column="1"
                                            Background="{Binding LevelBadgeBrush}"
                                            CornerRadius="2" Padding="4,1"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding LevelText}"
                                                   Foreground="#1A1A1A"
                                                   FontSize="9" FontWeight="Bold"
                                                   FontFamily="Courier New, monospace" />
                                    </Border>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Message}"
                                               Foreground="{Binding MessageBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Foreground="#888888"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,6,0,0"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    </Grid>

    <!-- Tonight's candidates overlay -->
    <Grid RowDefinitions="Auto,*"
          IsVisible="{Binding IsCandidatesOverlayOpen}"
          Background="#1A1A1A"
          ZIndex="10">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="20,20,20,12">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="Tonight's Targets"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="#E0E0E0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding CandidatesStatusText}"
                           Foreground="#555555" FontSize="11"
                           VerticalAlignment="Center" />
            </StackPanel>
            <Button Grid.Column="1" Classes="secondary"
                    Content="Close"
                    Command="{Binding CloseCandidatesOverlayCommand}"
                    FontSize="12" Padding="12,6" />
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="20,0,20,20" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="CandidatesFullList"
                          ItemsSource="{Binding TonightCandidatesFull}"
                          MaxWidth="680">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TonightCandidate">
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Rank, StringFormat='{}{0}.'}"
                                       Foreground="#555555" FontSize="13"
                                       VerticalAlignment="Top"
                                       Margin="0,2,12,0" Width="26" />
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#E0E0E0" FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TypeWindow}"
                                           Foreground="#777777" FontSize="11" />
                                <TextBlock Text="{Binding Imaged}"
                                           Foreground="#3A7BD5" FontSize="11"
                                           IsVisible="{Binding Imaged,
                                                       Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Classes="secondary"
                                    Content="Generate Plan"
                                    Command="{ReflectionBinding DataContext.GeneratePlanFromCandidateCommand, ElementName=CandidatesFullList}"
                                    CommandParameter="{Binding}"
                                    FontSize="11" Padding="10,6"
                                    VerticalAlignment="Top" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>

    <!-- Settings overlay — covers main content when open -->
    <Grid RowDefinitions="Auto,*"
          IsVisible="{Binding IsSettingsOpen}"
          Background="#1A1A1A"
          ZIndex="10">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="20,20,20,12">
            <TextBlock Text="Settings"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#E0E0E0"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Classes="secondary"
                    Content="Done"
                    Command="{Binding CloseSettingsCommand}"
                    FontSize="12" Padding="12,6" />
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="20,0,20,20" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" MaxWidth="560">

                <!-- Display preferences -->
                <Border Classes="card">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionHeader" Text="DISPLAY" />
                        <CheckBox IsChecked="{Binding UseFahrenheit}"
                                  Content="Use Fahrenheit (°F)"
                                  Foreground="#CCCCCC" FontSize="12" />
                        <TextBlock Text="Dew margin threshold is always entered in °C."
                                   Foreground="#555555" FontSize="10" />
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                            <TextBlock Text="Preview image max height"
                                       Foreground="#CCCCCC" FontSize="12"
                                       VerticalAlignment="Center" />
                            <TextBox Text="{Binding PreviewImageMaxHeight}"
                                     Width="70"
                                     Background="#1A1A1A" Foreground="#E0E0E0"
                                     BorderBrush="#444444" CaretBrush="#E0E0E0"
                                     Padding="8,6" CornerRadius="6" FontSize="13" />
                            <TextBlock Text="px"
                                       Foreground="#888888" FontSize="12"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Kasa Account -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="KASA ACCOUNT" />
                        <TextBox Text="{Binding KasaEmail}"
                                 Watermark="Kasa email"
                                 Background="#1A1A1A" Foreground="#E0E0E0"
                                 BorderBrush="#444444" CaretBrush="#E0E0E0"
                                 Padding="10,8" CornerRadius="6" FontSize="13" />
                        <TextBox Text="{Binding KasaPassword}"
                                 Watermark="Password"
                                 PasswordChar="●"
                                 Background="#1A1A1A" Foreground="#E0E0E0"
                                 BorderBrush="#444444" CaretBrush="#E0E0E0"
                                 Padding="10,8" CornerRadius="6" FontSize="13" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Classes="primary"
                                    Content="Reconnect"
                                    Command="{Binding ConnectKasaCommand}"
                                    IsEnabled="{Binding !IsKasaBusy}"
                                    FontSize="12" Padding="12,6" />
                            <TextBlock Text="{Binding KasaStatusMessage}"
                                       Foreground="#888888" FontSize="12"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding KasaStatusMessage,
                                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Camera Power -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="CAMERA POWER" />

                        <TextBlock Text="Configure Kasa credentials above first"
                                   Foreground="#666666" FontSize="12"
                                   IsVisible="{Binding !HasKasaDevices}" />

                        <ComboBox ItemsSource="{Binding KasaDevices}"
                                  SelectedItem="{Binding SelectedImagingDevice}"
                                  IsVisible="{Binding HasKasaDevices}"
                                  PlaceholderText="Select outlet…"
                                  Background="#1A1A1A" Foreground="#E0E0E0"
                                  BorderBrush="#444444" Padding="8,6"
                                  CornerRadius="6" FontSize="12"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:KasaDevice">
                                    <TextBlock Text="{Binding Alias}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Spacing="10"
                                    IsVisible="{Binding ImagingPowerConnected}"
                                    VerticalAlignment="Center">
                            <Button Classes="primary"
                                    Content="{Binding ImagingPowerButtonText}"
                                    Command="{Binding ToggleImagingPowerCommand}"
                                    IsEnabled="{Binding !IsKasaBusy}"
                                    FontSize="12" Padding="12,6" />
                            <Panel IsVisible="{Binding IsImagingPowerKnown}">
                                <Border CornerRadius="4" Padding="8,4"
                                        Background="#18261E"
                                        IsVisible="{Binding IsImagingPowerOn}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Ellipse Width="7" Height="7" Fill="#2ECC71" VerticalAlignment="Center" />
                                        <TextBlock Text="ON" Foreground="#2ECC71" FontSize="11" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="4" Padding="8,4"
                                        Background="#2A1510"
                                        IsVisible="{Binding !IsImagingPowerOn}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Ellipse Width="7" Height="7" Fill="#E74C3C" VerticalAlignment="Center" />
                                        <TextBlock Text="OFF" Foreground="#E74C3C" FontSize="11" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </Panel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ASI Air Power -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="ASI AIR POWER" />

                        <TextBlock Text="Configure Kasa credentials above first"
                                   Foreground="#666666" FontSize="12"
                                   IsVisible="{Binding !HasKasaDevices}" />

                        <ComboBox ItemsSource="{Binding KasaDevices}"
                                  SelectedItem="{Binding SelectedAsiAirDevice}"
                                  IsVisible="{Binding HasKasaDevices}"
                                  PlaceholderText="Select outlet…"
                                  Background="#1A1A1A" Foreground="#E0E0E0"
                                  BorderBrush="#444444" Padding="8,6"
                                  CornerRadius="6" FontSize="12"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:KasaDevice">
                                    <TextBlock Text="{Binding Alias}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Spacing="10"
                                    IsVisible="{Binding AsiAirPowerConnected}"
                                    VerticalAlignment="Center">
                            <Button Classes="primary"
                                    Content="{Binding AsiAirPowerButtonText}"
                                    Command="{Binding ToggleAsiAirPowerCommand}"
                                    IsEnabled="{Binding !IsKasaBusy}"
                                    FontSize="12" Padding="12,6" />
                            <Panel IsVisible="{Binding IsAsiAirPowerKnown}">
                                <Border CornerRadius="4" Padding="8,4"
                                        Background="#18261E"
                                        IsVisible="{Binding IsAsiAirPowerOn}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Ellipse Width="7" Height="7" Fill="#2ECC71" VerticalAlignment="Center" />
                                        <TextBlock Text="ON" Foreground="#2ECC71" FontSize="11" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="4" Padding="8,4"
                                        Background="#2A1510"
                                        IsVisible="{Binding !IsAsiAirPowerOn}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Ellipse Width="7" Height="7" Fill="#E74C3C" VerticalAlignment="Center" />
                                        <TextBlock Text="OFF" Foreground="#E74C3C" FontSize="11" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </Panel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Weather Monitoring -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="WEATHER MONITORING" />
                        <TextBlock Text="Auto-controls dew heater while a plan is running based on temperature vs. dew point margin."
                                   Foreground="#777777" FontSize="11" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Turn on within" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" />
                            <TextBox Text="{Binding DewMarginDisplay}"
                                     Width="56"
                                     Background="#1A1A1A" Foreground="#E0E0E0"
                                     BorderBrush="#444444" CaretBrush="#E0E0E0"
                                     Padding="8,7" CornerRadius="6" FontSize="12" />
                            <TextBlock Text="{Binding DewMarginUnitText}" Foreground="#888888" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Camera Cooling -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="CAMERA COOLING" />
                        <TextBlock Text="Pre-cool the camera before the plan starts imaging so you reach target temperature by first light."
                                   Foreground="#777777" FontSize="11" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Start cooling" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" />
                            <TextBox Text="{Binding CoolerPreCoolMinutesText}"
                                     Width="56"
                                     Background="#1A1A1A" Foreground="#E0E0E0"
                                     BorderBrush="#444444" CaretBrush="#E0E0E0"
                                     Padding="8,7" CornerRadius="6" FontSize="12" />
                            <TextBlock Text="minutes before plan starts  (0 = disabled)"
                                       Foreground="#888888" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Target temperature" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center" />
                            <TextBox Text="{Binding CoolerTargetTempText}"
                                     Width="56"
                                     Background="#1A1A1A" Foreground="#E0E0E0"
                                     BorderBrush="#444444" CaretBrush="#E0E0E0"
                                     Padding="8,7" CornerRadius="6" FontSize="12" />
                            <TextBlock Text="{Binding CoolerTempUnitText}" Foreground="#888888" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Image Sync -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Classes="sectionHeader" Text="IMAGE SYNC" VerticalAlignment="Center" />
                            <ToggleSwitch IsChecked="{Binding ImageSyncEnabled}"
                                          OnContent="" OffContent=""
                                          VerticalAlignment="Center" Margin="0,-4,0,0" />
                        </StackPanel>
                        <TextBlock Text="Copies new .fits files (preserving sub-folder structure) from source to destination after the plan completes. Retries any failures automatically."
                                   Foreground="#777777" FontSize="11" TextWrapping="Wrap" />
                        <TextBlock Text="Source folder" Foreground="#888888" FontSize="11" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding ImageSyncSourcePath}"
                                     Watermark="/Volumes/ASIAIR/Astronomy/…"
                                     Background="#1A1A1A" Foreground="#E0E0E0"
                                     BorderBrush="#444444" CaretBrush="#E0E0E0"
                                     Padding="10,8" CornerRadius="6" FontSize="12"
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="1" Classes="secondary" Content="Browse…"
                                    Click="BrowseSyncSource_Click" />
                        </Grid>
                        <TextBlock Text="Destination folder" Foreground="#888888" FontSize="11" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding ImageSyncDestPath}"
                                     Watermark="/Volumes/Backup/Astronomy/…"
                                     Background="#1A1A1A" Foreground="#E0E0E0"
                                     BorderBrush="#444444" CaretBrush="#E0E0E0"
                                     Padding="10,8" CornerRadius="6" FontSize="12"
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="1" Classes="secondary" Content="Browse…"
                                    Click="BrowseSyncDest_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Notifications -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="NOTIFICATIONS" />
                        <TextBlock Text="Paste a Discord webhook URL to receive log messages on your phone."
                                   Foreground="#777777" FontSize="11" TextWrapping="Wrap" />
                        <TextBox Text="{Binding DiscordWebhookUrl}"
                                 Watermark="https://discord.com/api/webhooks/…"
                                 Background="#1A1A1A" Foreground="#E0E0E0"
                                 BorderBrush="#444444" CaretBrush="#E0E0E0"
                                 Padding="10,8" CornerRadius="6" FontSize="12" />
                    </StackPanel>
                </Border>

                <!-- Device Connection -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="DEVICE" />
                        <TextBox Text="{Binding IpAddress}"
                                 Watermark="ASI Air IP address (e.g. 192.168.1.90)"
                                 Background="#1A1A1A" Foreground="#E0E0E0"
                                 BorderBrush="#444444" CaretBrush="#E0E0E0"
                                 Padding="10,8" CornerRadius="6" FontSize="13" />
                        <TextBlock Text="Starfront building number"
                                   Foreground="#888888" FontSize="11" Margin="0,4,0,0" />
                        <TextBox Text="{Binding StarfrontBuildingIdText}"
                                 Watermark="Building number (e.g. 5)"
                                 Background="#1A1A1A" Foreground="#E0E0E0"
                                 BorderBrush="#444444" CaretBrush="#E0E0E0"
                                 Padding="10,8" CornerRadius="6" FontSize="13" />
                        <TextBlock Text="Observatory time zone — used for sun timeline and condition times (IANA ID)"
                                   Foreground="#888888" FontSize="11" Margin="0,8,0,0" />
                        <TextBox Text="{Binding ObservatoryTimeZoneId}"
                                 Watermark="e.g. America/Chicago"
                                 Background="#1A1A1A" Foreground="#E0E0E0"
                                 BorderBrush="#444444" CaretBrush="#E0E0E0"
                                 Padding="10,8" CornerRadius="6" FontSize="13" />
                        <TextBlock Text="Common IDs: America/Chicago · America/New_York · America/Denver · America/Los_Angeles · America/Phoenix · UTC"
                                   Foreground="#3A3A3A" FontSize="10" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                            <TextBlock Text="Mount location:" Foreground="#888888" FontSize="11" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding MountLocationText}" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Observatory Location (for target planner) -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="OBSERVATORY LOCATION" />
                        <TextBlock Text="Used by the auto-target planner to compute object visibility and sky quality."
                                   Foreground="#777777" FontSize="11" TextWrapping="Wrap" />
                        <TextBox Text="{Binding ObservatoryName}"
                                 Watermark="Observatory name"
                                 Background="#1A1A1A" Foreground="#E0E0E0"
                                 BorderBrush="#444444" CaretBrush="#E0E0E0"
                                 Padding="10,8" CornerRadius="6" FontSize="13" />
                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Latitude (°, N positive)" Foreground="#888888" FontSize="11" />
                                <TextBox Text="{Binding ObservatoryLatitudeText}"
                                         Watermark="e.g. 30.25"
                                         Background="#1A1A1A" Foreground="#E0E0E0"
                                         BorderBrush="#444444" CaretBrush="#E0E0E0"
                                         Padding="10,8" CornerRadius="6" FontSize="13" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Longitude (°, W negative)" Foreground="#888888" FontSize="11" />
                                <TextBox Text="{Binding ObservatoryLongitudeText}"
                                         Watermark="e.g. -97.5"
                                         Background="#1A1A1A" Foreground="#E0E0E0"
                                         BorderBrush="#444444" CaretBrush="#E0E0E0"
                                         Padding="10,8" CornerRadius="6" FontSize="13" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Bortle class (1–9)" Foreground="#888888" FontSize="11" VerticalAlignment="Center" />
                            <TextBox Text="{Binding ObservatoryBortleText}"
                                     Width="52"
                                     Background="#1A1A1A" Foreground="#E0E0E0"
                                     BorderBrush="#444444" CaretBrush="#E0E0E0"
                                     Padding="8,7" CornerRadius="6" FontSize="12" />
                            <TextBlock Text="1=pristine dark · 4=rural · 6=suburban · 9=inner city"
                                       Foreground="#555555" FontSize="10" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Equipment — Telescope -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="TELESCOPE" />
                        <TextBox Text="{Binding TelescopeName}"
                                 Watermark="Telescope / optical train name"
                                 Background="#1A1A1A" Foreground="#E0E0E0"
                                 BorderBrush="#444444" CaretBrush="#E0E0E0"
                                 Padding="10,8" CornerRadius="6" FontSize="13" />
                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Aperture (mm)" Foreground="#888888" FontSize="11" />
                                <TextBox Text="{Binding TelescopeApertureText}"
                                         Watermark="e.g. 102"
                                         Background="#1A1A1A" Foreground="#E0E0E0"
                                         BorderBrush="#444444" CaretBrush="#E0E0E0"
                                         Padding="10,8" CornerRadius="6" FontSize="13" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Focal length (mm)" Foreground="#888888" FontSize="11" />
                                <TextBox Text="{Binding TelescopeFocalLengthText}"
                                         Watermark="e.g. 714"
                                         Background="#1A1A1A" Foreground="#E0E0E0"
                                         BorderBrush="#444444" CaretBrush="#E0E0E0"
                                         Padding="10,8" CornerRadius="6" FontSize="13" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Equipment — Camera -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="CAMERA" />
                        <TextBox Text="{Binding CameraName}"
                                 Watermark="Camera model name"
                                 Background="#1A1A1A" Foreground="#E0E0E0"
                                 BorderBrush="#444444" CaretBrush="#E0E0E0"
                                 Padding="10,8" CornerRadius="6" FontSize="13" />
                        <Grid ColumnDefinitions="*,12,*,12,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Pixel size (µm)" Foreground="#888888" FontSize="11" />
                                <TextBox Text="{Binding CameraPixelSizeText}"
                                         Watermark="e.g. 3.76"
                                         Background="#1A1A1A" Foreground="#E0E0E0"
                                         BorderBrush="#444444" CaretBrush="#E0E0E0"
                                         Padding="10,8" CornerRadius="6" FontSize="13" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Width (px)" Foreground="#888888" FontSize="11" />
                                <TextBox Text="{Binding CameraSensorWidthText}"
                                         Watermark="e.g. 4144"
                                         Background="#1A1A1A" Foreground="#E0E0E0"
                                         BorderBrush="#444444" CaretBrush="#E0E0E0"
                                         Padding="10,8" CornerRadius="6" FontSize="13" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="4">
                                <TextBlock Text="Height (px)" Foreground="#888888" FontSize="11" />
                                <TextBox Text="{Binding CameraSensorHeightText}"
                                         Watermark="e.g. 2822"
                                         Background="#1A1A1A" Foreground="#E0E0E0"
                                         BorderBrush="#444444" CaretBrush="#E0E0E0"
                                         Padding="10,8" CornerRadius="6" FontSize="13" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Auto-Target Planner Preferences -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="sectionHeader" Text="AUTO-TARGET PLANNER" />
                        <TextBlock Text="These preferences are used when Auto-Target mode is enabled on the Autopilot tab."
                                   Foreground="#777777" FontSize="11" TextWrapping="Wrap" />

                        <TextBlock Text="IMAGING DEFAULTS" Foreground="#666666" FontSize="10" Margin="0,4,0,0" />
                        <Grid ColumnDefinitions="*,12,Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Sub-exposure (sec)" Foreground="#888888" FontSize="11" />
                                <TextBox Text="{Binding PlannerSubExposureText}"
                                         Watermark="300"
                                         Background="#1A1A1A" Foreground="#E0E0E0"
                                         BorderBrush="#444444" CaretBrush="#E0E0E0"
                                         Padding="10,8" CornerRadius="6" FontSize="13" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Filter" Foreground="#888888" FontSize="11" />
                                <ComboBox SelectedItem="{Binding PlannerFilterType}"
                                          Background="#1A1A1A" Foreground="#E0E0E0"
                                          BorderBrush="#444444"
                                          Padding="8,7" CornerRadius="6" FontSize="12">
                                    <ComboBoxItem>Broadband</ComboBoxItem>
                                    <ComboBoxItem>Ha</ComboBoxItem>
                                    <ComboBoxItem>Oiii</ComboBoxItem>
                                    <ComboBoxItem>Sii</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="TARGET SELECTION" Foreground="#666666" FontSize="10" Margin="0,4,0,0" />
                        <Grid ColumnDefinitions="*,12,*,12,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Horizon (°)" Foreground="#888888" FontSize="11" />
                                <TextBox Text="{Binding PlannerHorizonFlatText}"
                                         Watermark="15"
                                         Background="#1A1A1A" Foreground="#E0E0E0"
                                         BorderBrush="#444444" CaretBrush="#E0E0E0"
                                         Padding="10,8" CornerRadius="6" FontSize="13" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Min altitude (°)" Foreground="#888888" FontSize="11" />
                                <TextBox Text="{Binding PlannerMinAltitudeText}"
                                         Watermark="20"
                                         Background="#1A1A1A" Foreground="#E0E0E0"
                                         BorderBrush="#444444" CaretBrush="#E0E0E0"
                                         Padding="10,8" CornerRadius="6" FontSize="13" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="4">
                                <TextBlock Text="Min moon separation (°)" Foreground="#888888" FontSize="11" />
                                <TextBox Text="{Binding PlannerMinMoonSepText}"
                                         Watermark="30"
                                         Background="#1A1A1A" Foreground="#E0E0E0"
                                         BorderBrush="#444444" CaretBrush="#E0E0E0"
                                         Padding="10,8" CornerRadius="6" FontSize="13" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
    </Panel>
</Window>
