<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AsiAirController.ViewModels"
        x:Class="AsiAirController.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ASI Air Controller"
        Width="780" Height="960"
        CanResize="True"
        MinWidth="640" MinHeight="600"
        Background="#1A1A1A">

    <Window.Styles>
        <Style Selector="TextBlock.sectionHeader">
            <Setter Property="Foreground" Value="#AAAAAA" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="1" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#242424" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#3A7BD5" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A8BE5" />
        </Style>
        <Style Selector="Button.primary:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="TextElement.Foreground" Value="#555555" />
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#C0392B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E74C3C" />
        </Style>
        <Style Selector="Button.danger:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="TextElement.Foreground" Value="#555555" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#444444" />
        </Style>
        <Style Selector="Button.secondary:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="TextElement.Foreground" Value="#555555" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">

        <TextBlock Grid.Row="0"
                   Text="ASI Air Controller"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#E0E0E0"
                   Margin="0,0,0,16" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0">

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="sectionHeader" Text="DEVICE" />
                    <TextBox Text="{Binding IpAddress}"
                             Watermark="ASI Air IP address (e.g. 172.17.14.146)"
                             Background="#1A1A1A"
                             Foreground="#E0E0E0"
                             BorderBrush="#444444"
                             CaretBrush="#E0E0E0"
                             Padding="10,8"
                             CornerRadius="6"
                             FontSize="13" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding RoofStatusFilePath}"
                                 Watermark="Roof status file path (optional)"
                                 Background="#1A1A1A"
                                 Foreground="#E0E0E0"
                                 BorderBrush="#444444"
                                 CaretBrush="#E0E0E0"
                                 Padding="10,8"
                                 CornerRadius="6"
                                 FontSize="13"
                                 Margin="0,0,8,0" />
                        <Button Grid.Column="1"
                                Classes="secondary"
                                Content="Browse…"
                                Click="BrowseRoofFile_Click" />
                    </Grid>
                    <ComboBox ItemsSource="{Binding AvailableRoofKeys}"
                              SelectedItem="{Binding RoofKey}"
                              PlaceholderText="Loading roofs…"
                              Background="#1A1A1A"
                              Foreground="#E0E0E0"
                              BorderBrush="#444444"
                              Padding="10,8"
                              CornerRadius="6"
                              FontSize="13"
                              HorizontalAlignment="Stretch" />
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Classes="sectionHeader" Text="ACTIONS" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Text="{Binding ExposureSeconds}"
                                 Width="60"
                                 Background="#1A1A1A"
                                 Foreground="#E0E0E0"
                                 BorderBrush="#444444"
                                 CaretBrush="#E0E0E0"
                                 Padding="8,7"
                                 CornerRadius="6"
                                 FontSize="13" />
                        <TextBlock Text="sec" Foreground="#888888" FontSize="12"
                                   VerticalAlignment="Center" />
                        <Button Classes="primary" Content="Take Image"
                                Command="{Binding TakeImageCommand}" />
                    </StackPanel>
                    <WrapPanel>
                        <Button Classes="secondary" Content="Stop Exposure"
                                Command="{Binding StopExposureCommand}"
                                Margin="0,0,10,8" />
                        <Button Classes="primary" Content="Park Mount"
                                Command="{Binding ParkMountCommand}"
                                Margin="0,0,10,8" />
                        <Button Classes="danger" Content="Safe Shutdown"
                                Command="{Binding SafeShutdownCommand}"
                                Margin="0,0,10,8" />
                        <Button Classes="secondary"
                                Content="{Binding PollRoofButtonText}"
                                Command="{Binding PollRoofCommand}"
                                Margin="0,0,10,8" />
                        <Button Classes="secondary" Content="Check Roof"
                                Command="{Binding CheckRoofStatusCommand}"
                                Margin="0,0,10,8" />
                        <Button Classes="secondary" Content="Test"
                                Command="{Binding TestCommand}"
                                Margin="0,0,10,8" />
                        <Button Classes="secondary"
                                Content="{Binding TogglePreviewButtonText}"
                                Command="{Binding TogglePreviewCommand}"
                                Margin="0,0,0,8" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Classes="card"
                    IsVisible="{Binding IsPollingRoof}"
                    Margin="0,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="8" Height="8" Fill="#2ECC71" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding RoofPollStatus}"
                               Foreground="#E0E0E0"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border Classes="card"
                    IsVisible="{Binding IsPreviewActive}"
                    Margin="0,12,0,0">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="sectionHeader" Text="LIVE PREVIEW" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PreviewStatus}"
                                   Foreground="#888888" FontSize="11"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <Border Height="460" Background="#0D0D0D" CornerRadius="4">
                        <Panel>
                            <TextBlock Text="Waiting for first image..."
                                       Foreground="#555555" FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding PreviewBitmap,
                                                   Converter={x:Static ObjectConverters.IsNull}}" />
                            <Image Source="{Binding PreviewBitmap}"
                                   Stretch="Uniform"
                                   IsVisible="{Binding PreviewBitmap,
                                               Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </Panel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="#888888"
                   FontSize="11"
                   TextWrapping="Wrap"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    </Grid>
</Window>
